# ---- Database ----
# Local dev default: mongodb://localhost:27017/trugo-sync
# Production (MongoDB Atlas): mongodb+srv://USER:PASS@cluster.mongodb.net/trugo-sync?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/trugo-sync

# ---- Auth ----
# Use a long random string in production
JWT_SECRET=super-secret
# Login session length (e.g. 8h, 12h, 24h). Default in code: 12h
JWT_EXPIRES_IN=12h

# ---- Frontend URL (used in password reset links) ----
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ---- Server ----
# Render sets PORT automatically; leave unset locally to default to 5000
# PORT=5000

# ---- Gmail SMTP ----
# Set SMTP_PASS to your Google App Password (16 chars): https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=REPLACE_WITH_YOUR_GMAIL_APP_PASSWORD
SMTP_FROM=Trugo Sync <your-email@gmail.com>
SMTP_TLS_REJECT_UNAUTHORIZED=false

# ---- Office GPS (clock-in geofence) ----
# Trugo office — https://maps.app.goo.gl/pn8pQvdsLWpoFaA47
OFFICE_LAT=11.669207222195348
OFFICE_LNG=78.14333126167497
# Allowed radius in meters (1.5 km)
OFFICE_RADIUS_METERS=1500
